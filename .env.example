# ── Banco de dados (Supabase — gratuito) ──────────────────
# Pegue em: supabase.com → seu projeto → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[SUA-SENHA]@db.[SEU-PROJETO].supabase.co:5432/postgres

# ── Redis (Upstash — gratuito) ─────────────────────────────
# Pegue em: upstash.com → seu database → Details → REDIS_URL
REDIS_URL=rediss://default:[TOKEN]@[HOST].upstash.io:6379

# ── Claude API ────────────────────────────────────────────
CLAUDE_API_KEY=your_claude_api_key_here

# ── Meta Ads (opcional) ───────────────────────────────────
META_ACCESS_TOKEN=your_meta_access_token
META_AD_ACCOUNT=your_ad_account_id

# ── WordPress (opcional) ──────────────────────────────────
WP_URL=http://your-wordpress-url
WP_USER=admin
WP_PASS=password

# ── HuggingFace (opcional) ────────────────────────────────
HF_TOKEN=your_huggingface_token

# ── URL pública do backend (preencher após deploy no Render) ──
BACKEND_URL=https://sales-machine-api.onrender.com
